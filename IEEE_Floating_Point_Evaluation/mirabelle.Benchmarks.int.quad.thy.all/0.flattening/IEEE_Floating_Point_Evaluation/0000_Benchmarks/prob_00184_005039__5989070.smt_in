; As of now it is a bit unclear how exactly a correct SMT-LIB 3 model is formatted.
; Hence, this will be corrected once the standard is released.
; No options
(import (FloatingPoint, Reals, Ints))
(open (FloatingPoint, Reals, Ints))
(declare-const z$ (FloatingPoint 15 113))
(declare-const y$ (FloatingPoint 15 113))
(declare-const x$ (FloatingPoint 15 113))
(declare-const is_finite$ (-> (FloatingPoint 15 113) Bool))
(assert (! (not (fp.leq x$ z$)) :named conjecture0))
(assert (! (is_finite$ x$) :named hypothesis1))
(assert (! (is_finite$ y$) :named hypothesis2))
(assert (! (is_finite$ z$) :named hypothesis3))
(assert (! (fp.leq x$ y$) :named hypothesis4))
(assert (! (fp.leq y$ z$) :named hypothesis5))
(check-sat)
(get-proof)
