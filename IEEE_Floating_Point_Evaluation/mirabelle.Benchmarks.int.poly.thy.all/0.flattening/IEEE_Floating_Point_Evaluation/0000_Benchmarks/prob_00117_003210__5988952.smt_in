; As of now it is a bit unclear how exactly a correct SMT-LIB 3 model is formatted.
; Hence, this will be corrected once the standard is released.
; No options
(import (FloatingPoint, Reals, Ints))
(open (FloatingPoint, Reals, Ints))
(declare-const x_f$ Int)
(declare-const x_e$ Int)
(declare-const x$ (FloatingPoint x_e$ (+ x_f$ 1)))
(declare-const is_finite$ (-> (FloatingPoint x_e$ (+ x_f$ 1)) Bool))
(assert (! (not (not (and (fp.isInfinite x$) (is_finite$ x$)))) :named conjecture0))
(check-sat)
(get-proof)
