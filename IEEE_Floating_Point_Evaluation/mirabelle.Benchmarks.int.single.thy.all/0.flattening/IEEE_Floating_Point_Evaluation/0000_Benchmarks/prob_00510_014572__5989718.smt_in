; As of now it is a bit unclear how exactly a correct SMT-LIB 3 model is formatted.
; Hence, this will be corrected once the standard is released.
; No options
(import (FloatingPoint, Reals, Ints))
(open (FloatingPoint, Reals, Ints))
(declare-const mode$ RoundingMode)
(declare-const y$ (FloatingPoint 8 24))
(declare-const x$ (FloatingPoint 8 24))
(declare-const divide$ (-> Real Real Real))
(declare-const is_finite$ (-> (FloatingPoint 8 24) Bool))
(assert (! (not (= (- (fp.to_real x$) (fp.to_real y$)) (fp.to_real (fp.sub mode$ x$ y$)))) :named conjecture0))
(assert (! (is_finite$ x$) :named hypothesis1))
(assert (! (is_finite$ y$) :named hypothesis2))
(assert (! (and (<= (divide$ (fp.to_real y$) 2.0) (fp.to_real x$)) (<= (fp.to_real x$) (* 2.0 (fp.to_real y$)))) :named hypothesis3))
(check-sat)
(get-proof)
